# Spotify API Configuration
# Diese Werte erhältst du von https://developer.spotify.com/dashboard

VITE_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
# Bei PKCE wird kein Client Secret im Frontend benoetigt.
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/kinder-hoerspiele/

# Für Production (nach Deploy auf GitHub Pages):
# VITE_SPOTIFY_REDIRECT_URI=https://frank-privat.github.io/kinder-hoerspiele/

# Admin Panel Password (optional)
VITE_ADMIN_PASSWORD=admin123

# Optional: Eltern-PIN lokal in der Entwicklung deaktivieren
# VITE_DISABLE_PIN_PROTECTION=true

# Optional: Master-PIN zum Umgehen der Eltern-PIN
# VITE_MASTER_PIN=9999
